		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"eslint": "^8.57.1",
		"eslint-plugin-obsidianmd": "^0.2.4",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
